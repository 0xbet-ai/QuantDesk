{
  "name": "quantdesk",
  "private": true,
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "dev": "pnpm --filter server dev & pnpm --filter ui dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "test": "vitest run",
    "db:migrate": "pnpm --filter @quantdesk/db migrate",
    "db:generate": "pnpm --filter @quantdesk/db generate",
    "db:seed": "pnpm --filter @quantdesk/db seed",
    "db:reset": "pnpm --filter @quantdesk/db reset && pnpm db:migrate && pnpm db:seed",
    "clean:runs": "rm -rf server/workspaces ~/.quantdesk/logs ~/.quantdesk/datacache && pnpm db:reset",
    "build:generic-image": "docker build -t quantdesk/generic:0.1.0 docker/generic/",
    "onboard": "pnpm --filter quantdesk onboard"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "typescript": "^5.7.3",
    "vitest": "^3.1.1"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=8"
  },
  "packageManager": "pnpm@8.15.5",
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.25.0"
    }
  }
}
